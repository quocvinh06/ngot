# Copy to .streamlit/secrets.toml and fill in real values.
# DO NOT commit secrets.toml — already in .gitignore.

# Two-tier shared-password auth (Pattern: streamlit-shared-password)
AUTH_PASSWORD = "change-me-staff-password"
ADMIN_PASSWORD = "change-me-admin-password"

# Google Sheets target (the spreadsheet must be shared with the service account email below as Editor)
SHEETS_URL = "https://docs.google.com/spreadsheets/d/REPLACE_ME/edit"

# Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY = "REPLACE_ME"

# Telegram bot integration (BotFather → /newbot)
TELEGRAM_BOT_TOKEN = "REPLACE_ME"
TELEGRAM_CHAT_ID = "REPLACE_ME"

# Google Cloud service account JSON — paste the entire JSON object under this key
[gcp_service_account]
type = "service_account"
project_id = "REPLACE_ME"
private_key_id = "REPLACE_ME"
private_key = "-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
client_email = "REPLACE_ME@REPLACE_ME.iam.gserviceaccount.com"
client_id = "REPLACE_ME"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "REPLACE_ME"
universe_domain = "googleapis.com"
